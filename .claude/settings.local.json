{
  "env": {
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5-20251001"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(echo *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(node *)",
      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(bash .claude/hooks/auto-commit-push.sh)",
      "Read(~/.claude/**)",
      "Skill(update-config)",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit-push.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
